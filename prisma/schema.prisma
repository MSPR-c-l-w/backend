// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                                  Int              @id @default(autoincrement())
  organization_id                     Int?
  organization                        Organization?    @relation(fields: [organization_id], references: [id])
  email                               String           @unique
  password_hash                       String
  refresh_token_hash                  String?          @unique
  refresh_token_expires_at            DateTime?
  email_verification_token_hash       String?          @unique
  email_verification_token_expires_at DateTime?
  email_verified_at                   DateTime?
  reset_password_token_hash           String?          @unique
  reset_password_token_expires_at     DateTime?
  first_name                          String
  last_name                           String
  date_of_birth                       DateTime?
  gender                              String?
  height                              Float?
  created_at                          DateTime         @default(now())
  updated_at                          DateTime         @updatedAt
  deleted_at                          DateTime?
  is_active                           Boolean          @default(true)
  is_deleted                          Boolean          @default(false)
  workoutSessions                     WorkoutSession[]
}

model Organization {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  type            String
  branding_config Json
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?
  is_active       Boolean   @default(true)
  is_deleted      Boolean   @default(false)
  users           User[]
}

model WorkoutSession {
  id             Int           @id @default(autoincrement())
  user_id        Int
  duration_h     Float
  calories_total Int
  avg_bpm        Int
  max_bpm        Int
  created_at     DateTime      @default(now())
  user           User          @relation(fields: [user_id], references: [id])
  logs           ExerciseLog[]
}

model ExerciseLog {
  id          Int            @id @default(autoincrement())
  exercise_id Int
  session_id  Int
  exercise    Exercise       @relation(fields: [exercise_id], references: [id])
  session     WorkoutSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model Exercise {
  id                Int           @id @default(autoincrement())
  name              String        @unique
  primary_muscles   Json?
  secondary_muscles Json?
  level             String?
  mechanic          String?
  equipment         String?
  category          String?
  instructions      Json?
  image_urls        Json?
  exercise_type     String?
  exerciseLogs      ExerciseLog[]
}

model Nutrition {
  id              Int     @id @default(autoincrement())
  name            String
  category        String
  calories_kcal   Float
  protein_g       Float
  carbohydrates_g Float
  fat_g           Float
  fiber_g         Float
  sugar_g         Float
  sodium_mg       Float
  cholesterol_mg  Float
  meal_type_name  String
  water_intake_ml Float
  picture_url     String?
}

model Plan {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  features Json
}

model HealthProfile {
  id                      Int      @id @default(autoincrement())
  user_id                 Int
  weight                  Float?
  bmi                     Float?
  disease_type            String?
  severity                String?
  physical_activity_level String?
  daily_calories_target   Int?
  updated_at              DateTime  @updatedAt
}

model Subscription {
  id Int @id @default(autoincrement())
  user_id Int
  plan_id Int
  start_date DateTime @default(now())
  end_date DateTime
  status String
}
